# Copy to appdaemon/apps/apps.yaml on the HA host and fill in serial numbers.
# apps.yaml is listed in .gitignore and will never be committed.

laadplanner:
  module: laadplanner.laadplanner_app
  class: ChargeScheduler

  location:
    latitude: 52.09
    longitude: 5.23

  panels:
    - name: SE
      kwp: 2.58
      azimuth: -45
      tilt: 35
    - name: NE
      kwp: 1.29
      azimuth: -135
      tilt: 35

  entities:
    soc_sensor:         "sensor.volkswagen_YOUR_SERIAL_state_of_charge"
    cable_sensor:       "binary_sensor.ratio_YOUR_SERIAL_vehicle_connected"
    charge_mode_select: "select.ratio_YOUR_SERIAL_charge_mode"
    charge_target:      "input_number.laad_doel"
    charge_by:          "input_datetime.laad_klaar_om"

  vehicle:
    battery_kwh: 77
    charging_power_kw: 11.0

  fixed_rate:
    day_rate_ct:   27.0   # 06:00–22:00
    night_rate_ct: 23.0   # 22:00–06:00
