# Copy to /addon_configs/a0d7b954_appdaemon/apps/apps.yaml on the HA host and fill in your values.
# apps.yaml is listed in .gitignore and will never be committed.

charger:
  module: charger.charger_app
  class: ChargeScheduler

  location:
    latitude: 52.09
    longitude: 5.23

  panels:
    - name: SE
      kwp: 2.58
      azimuth: -45
      tilt: 35
    - name: NE
      kwp: 1.29
      azimuth: -135
      tilt: 35

  entities:
    soc_sensor:         "sensor.YOUR_EV_state_of_charge"
    cable_sensor:       "binary_sensor.ratio_YOUR_SERIAL_vehicle_connected"
    charge_mode_select: "select.ratio_YOUR_SERIAL_charge_mode"
    charge_target:      "input_number.charge_target"
    charge_by:          "input_datetime.charge_by"

  vehicle:
    battery_kwh: 77
    charging_power_kw: 11.0

  tariff:
    grid:
      type: fixed
      price: 0.27       # EUR/kWh (default rate)
      zones:
        - hours: "22-6"
          price: 0.23   # EUR/kWh (night rate)
